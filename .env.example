# Email settings (Gmail example)
EMAIL_ENABLED=true
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com
EMAIL_PASSWORD=your_app_password # Use an App Password, not your normal password

# Discord webhook (optional)
DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_token

# Monitoring interval (seconds)
CHECK_INTERVAL=60

# Web server binding (use 0.0.0.0 for all interfaces, localhost for local only)
HOST=0.0.0.0
# Port (many hosting platforms set this automatically)
PORT=8000

SSL_ENABLED=false
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem